# =============================================================
# SECRETS — NEVER COMMIT (broad glob patterns across whole repo)
# =============================================================

# Any private key / cert / token / credential anywhere
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/id_rsa*
**/id_ed25519*
**/credentials.json
**/service-account*.json
**/gcp-*.json
**/*-iam-*.txt
**/*-iam-credentials*
**/token.json
**/tokens.json
**/auth_token*
**/oauth_token*

# BMO-specific secrets (most caught by the broad globs above — explicit for clarity)
bmo/pi-iam-credentials.txt
bmo/.env
bmo/pi/.env
bmo/config/.env
bmo/pi/*.pem
bmo/pi/config/*.json

# DnD app secrets
/.env
src/**/.env

# BMO runtime (generated, not secret but noisy)
bmo/pi/venv/
bmo/pi/logs/
bmo/pi/.bmo/
bmo/pi/.audiocache/
bmo/pi/wake_clips/
bmo/pi/*.ppn
bmo/pi/.pytest_cache/

# BMO runtime state — generated at runtime, NOT source content.
# bmo/pi/data/ also contains content subdirs (5e/, personality/, rag_data/, games/, etc.)
# so we enumerate specific runtime files rather than glob *.json.
bmo/pi/data/logs/
bmo/pi/data/memory/
bmo/pi/data/*.db
bmo/pi/data/alarms.json
bmo/pi/data/alert_history.json
bmo/pi/data/ide_jobs.json
bmo/pi/data/ide_state.json
bmo/pi/data/location_cache.json
bmo/pi/data/monitor_state.json
bmo/pi/data/monitor_alert_state.json
bmo/pi/data/music_history.json
bmo/pi/data/notes.json
bmo/pi/data/play_counts.json
bmo/pi/data/playback_state.json
bmo/pi/data/recent_chat.json
bmo/pi/data/settings.json
bmo/pi/data/dnd_sessions/

# Hardware LED / local UI state (runtime)
bmo/pi/hardware/data/

# Monitoring agents write here — entire dir is runtime state
bmo/pi/services/data/*.json
bmo/pi/services/data/*.db

# Python bytecode anywhere
**/__pycache__/
**/*.pyc

# Broken / backup venv dirs (not the canonical bmo/pi/venv/)
bmo/pi/venv.broken.*/

# Local-only security log + its resolved-archive (kept out of git so concerns/incidents stay local)
docs/SECURITY-LOG.md
docs/RESOLVED-SECURITY-ISSUES.md

# Test artifacts at root
test-results*.txt
**/venv/
