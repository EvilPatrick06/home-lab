# BMO Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.template .env && nano .env
#
# All commands via "bash bmo.sh <command>" will source this file
# automatically. Values here override script defaults.

# ── Cloud AI API Keys ─────────────────────────────────────────────────
# Primary LLM (Gemini 3 Pro / Flash)
GEMINI_API_KEY=""                 # https://aistudio.google.com/apikey

# D&D DM model (Claude Opus 4.6)
ANTHROPIC_API_KEY=""              # https://console.anthropic.com/settings/keys

# Speech-to-Text (Groq Whisper)
GROQ_API_KEY=""                   # https://console.groq.com/keys

# Text-to-Speech (Fish Audio)
FISH_AUDIO_API_KEY=""             # https://fish.audio/account/api-keys — rotate before committing!
FISH_AUDIO_VOICE_ID="94b4570683534e37993fdffbd47d084b"  # BMO voice clone

# Vision (Google Cloud Vision)
GOOGLE_VISION_API_KEY=""          # https://console.cloud.google.com/apis/credentials

# ── Model Selection ───────────────────────────────────────────────────
BMO_PRIMARY_MODEL="gemini-3-pro"  # General assistant
BMO_ROUTER_MODEL="gemini-3-flash" # Fast routing / simple queries
BMO_DND_MODEL="claude-opus-4.6"   # D&D Dungeon Master

# ── Raspberry Pi ──────────────────────────────────────────────────────
PI_IP=""                         # Local IP of your Pi (e.g. 10.10.20.242)
PI_USER="patrick"
PI_HOSTNAME="bmo"
PI_TIMEZONE="America/Denver"

# ── Flask / App ───────────────────────────────────────────────────────
SECRET_KEY=""                     # Flask session secret (auto-generated if empty)

# ── NPC Voice IDs (Fish Audio, optional) ──────────────────────────────
# Set these after uploading NPC voice clones to Fish Audio
# FISH_AUDIO_NPC_GRUFF_DWARF=""
# FISH_AUDIO_NPC_MYSTERIOUS_ELF=""
# FISH_AUDIO_NPC_BOOMING_DRAGON=""
# FISH_AUDIO_NPC_WHISPERY_ROGUE=""
# FISH_AUDIO_NPC_ELDERLY_WIZARD=""
# FISH_AUDIO_NPC_CHEERFUL_BARD=""
# FISH_AUDIO_NPC_STERN_GUARD=""
# FISH_AUDIO_NPC_TAVERN_KEEPER=""

# ── Monitoring / Alerts ────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=""            # Discord webhook for BMO alerts (Server Settings → Integrations → Webhooks)

# ── Discord Bots ──────────────────────────────────────────────────────
DISCORD_DM_BOT_TOKEN=""           # DM bot token (Discord Developer Portal → Bot)
DISCORD_SOCIAL_BOT_TOKEN=""       # Social bot token (Discord Developer Portal → Bot)
DISCORD_GUILD_ID=""               # Server (guild) ID for slash command registration

# ── Cloudflare (optional, for TURN relay) ─────────────────────────────
CF_TUNNEL_ID=""
CF_ACCOUNT_ID=""
