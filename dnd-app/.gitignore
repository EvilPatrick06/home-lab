# Biome (biome.json vcs.useIgnoreFile) requires a ignore file in this directory.
# Monorepo-wide rules: ../.gitignore (do not symlink — breaks Git + Biome on this setup).

node_modules/
out/
dist/
*.log
# rollup-plugin-visualizer (ANALYZE=1 npm run build)
bundle-stats.html
# Bundled Ollama binary — fetched at build time per platform, not source-tracked
resources/ollama/
.ollama-download-tmp/
