{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "electron.vite.config.ts",
    "src/main/index.ts",
    "src/preload/index.ts",
    "src/renderer/src/main.tsx",
    "scripts/**/*.ts",
    "scripts/**/*.mjs",
    "tools/**/*.js"
  ],
  "ignore": ["src/renderer/public/pdf.worker.min.mjs", "**/*.d.ts"],
  "ignoreDependencies": [
    "jscpd",
    "license-checker",
    "lockfile-lint",
    "npm-check-updates",
    "oxlint",
    "ts-prune",
    "type-coverage"
  ]
}
