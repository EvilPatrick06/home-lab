# BMO — Python dependencies for Raspberry Pi 5
# Pin setuptools for known CVEs (pip/venv build)
setuptools>=78.1.1,<82
#
# PyTorch: install CPU-only BEFORE the rest, or a plain `pip install -r` on Linux aarch64
# may resolve torch from PyPI with CUDA + nvidia wheels (~4.5+ GB) — useless on Pi 5.
#   ./venv/bin/pip install torch --index-url https://download.pytorch.org/whl/cpu
#   ./venv/bin/pip install -r requirements.txt
# Or: bash scripts/install-venv.sh
#
# resemblyzer / openwakeword pull torch; order matters. Do not add a bare `torch` line here
# without the CPU install step above (setup-bmo.sh and install-venv.sh do it right).

# Core AI
ollama

# Wake word detection
openwakeword

# Speaker verification
resemblyzer

# TTS — local fallback only (cloud primary is Fish Audio)
piper-tts

# Vision — local fallback only (cloud primary is Google Vision)
opencv-python-headless

# Audio
pyaudio
sounddevice
numpy

# Web framework
flask
flask-socketio
# flask-limiter — per-IP rate limits on cost-sensitive routes (chat, dnd-load,
# ide-jobs). Localhost exempt; memory-backed (single-process gevent — fine).
flask-limiter
gevent
gevent-websocket

# Google APIs (Calendar)
google-api-python-client
google-auth-oauthlib

# Smart home / Chromecast
pychromecast

