mcp
httpx
sseclient-py

# Cloud API helpers
requests

# Used directly by app / bots (were missing from this file; fresh venvs failed)
python-dotenv
# discord.py — pin >=2.6 to defeat pip-compile's tendency to pick the
# unrelated abandoned `discord-py 0.9.2` (dash vs dot is a real footgun
# on piwheels' name-normalization).
#
# IMPORTANT: NOT using `[voice]` extra. The extra pins `PyNaCl<1.6`
# (conservative upstream cap, not a real API requirement) which conflicts
# with the `PyNaCl>=1.6.2` security pin below. discord.py only uses
# `nacl.secret.SecretBox` whose API is identical in 1.5 / 1.6, so voice
# works with the unrolled deps. libopus (the other voice prereq) is a
# system C library, installed via apt by setup-bmo.sh, not a Python dep.
discord.py>=2.6,<3.0
# PyNaCl — voice encryption + security pin (CVE-2025-69277 fixed in 1.6.2+)
PyNaCl>=1.6.2
edge-tts
scipy

